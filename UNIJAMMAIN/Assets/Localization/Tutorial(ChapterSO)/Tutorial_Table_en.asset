MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: Tutorial_Table_en
  m_EditorClassIdentifier: 
  m_LocaleId:
    m_Code: en
  m_SharedData: {fileID: 11400000, guid: f68a5f249762c2b4a9833b0311d64148, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 846767249977344
    m_Localized: (I said that, but honestly, I've never faced one.)
    m_Metadata:
      m_Items: []
  - m_Id: 846767270948864
    m_Localized: (For enemies from the four directions... press WASD to strike!)
    m_Metadata:
      m_Items: []
  - m_Id: 846767270948865
    m_Localized: I must follow Master's words... Alright, let's do this!
    m_Metadata:
      m_Items: []
  - m_Id: 846767270948866
    m_Localized: I think I've got this.
    m_Metadata:
      m_Items: []
  - m_Id: 846767270948867
    m_Localized: Harder than I thought.
    m_Metadata:
      m_Items: []
  - m_Id: 846767270948868
    m_Localized: Those... Dark Spirits that look like me... could it be...
    m_Metadata:
      m_Items: []
  - m_Id: 846767270948869
    m_Localized: To think the greatest trial is myself... Wait, what did Master say
      about this?
    m_Metadata:
      m_Items: []
  - m_Id: 846767270948870
    m_Localized: (When a Shadow Wraith tries to consume you, strike with the diagonal
      keys!)
    m_Metadata:
      m_Items: []
  - m_Id: 846767270948871
    m_Localized: Diagonal...? For top-right, press the Up + Right arrow keys together?
    m_Metadata:
      m_Items: []
  - m_Id: 846767270948872
    m_Localized: They look rather... terrifying.
    m_Metadata:
      m_Items: []
  - m_Id: 846767270948873
    m_Localized: I feel like I'm losing my mind.
    m_Metadata:
      m_Items: []
  - m_Id: 846767270948874
    m_Localized: More Dark Spirits are swarming. I must stay sharp!
    m_Metadata:
      m_Items: []
  - m_Id: 846767270948875
    m_Localized: I'll show you the fate of those who defy Harmony.
    m_Metadata:
      m_Items: []
  - m_Id: 846767270948876
    m_Localized: They're relentlessly tracking me all the way here.
    m_Metadata:
      m_Items: []
  - m_Id: 846767270948877
    m_Localized: Wait, they're moving way too fast!
    m_Metadata:
      m_Items: []
  - m_Id: 846767270948878
    m_Localized: The fog is thickening..! They're using the cover to swarm again.
    m_Metadata:
      m_Items: []
  - m_Id: 846767270948879
    m_Localized: I will prove that the weight of my Faith,
    m_Metadata:
      m_Items: []
  - m_Id: 846767270948880
    m_Localized: is greater than yours, Master.
    m_Metadata:
      m_Items: []
  - m_Id: 846767270948881
    m_Localized: Their Qi is overwhelming. It takes two strikes to dispel them.
    m_Metadata:
      m_Items: []
  - m_Id: 846767270948883
    m_Localized: I shall overturn your vision with the logic of the strong.
    m_Metadata:
      m_Items: []
  - m_Id: 846767270948884
    m_Localized: Can you still illuminate the path in this reversed world?
    m_Metadata:
      m_Items: []
  - m_Id: 846767270948885
    m_Localized: Toward The Origin,
    m_Metadata:
      m_Items: []
  - m_Id: 846767270948886
    m_Localized: I shall press on until this body shatters.
    m_Metadata:
      m_Items: []
  - m_Id: 846767270948887
    m_Localized: Stay right there, true to your stubborn Faith!
    m_Metadata:
      m_Items: []
  - m_Id: 846767270948888
    m_Localized: I'll shatter them with all my might.
    m_Metadata:
      m_Items: []
  - m_Id: 846767270948889
    m_Localized: A false Sanctuary cannot obscure The Buddha.
    m_Metadata:
      m_Items: []
  - m_Id: 846767270948890
    m_Localized: Even if I must willingly offer my life,
    m_Metadata:
      m_Items: []
  - m_Id: 846767270948891
    m_Localized: To dare trespass upon this sacred ground...
    m_Metadata:
      m_Items: []
  - m_Id: 846767270948892
    m_Localized: Prepare to face your reckoning.
    m_Metadata:
      m_Items: []
  - m_Id: 846767270948893
    m_Localized: I cannot... fall here.
    m_Metadata:
      m_Items: []
  - m_Id: 846767270948894
    m_Localized: Come... I will stand my ground and hold fast.
    m_Metadata:
      m_Items: []
  - m_Id: 846767270948895
    m_Localized: Here, where it all began,
    m_Metadata:
      m_Items: []
  - m_Id: 846767270948896
    m_Localized: I will bring this to an end with my own hands.
    m_Metadata:
      m_Items: []
  - m_Id: 846767270948897
    m_Localized: I am still standing strong!
    m_Metadata:
      m_Items: []
  - m_Id: 846767270948898
    m_Localized: I will sever this endless Ill-Fated tie right here.
    m_Metadata:
      m_Items: []
  - m_Id: 846767270948899
    m_Localized: Still unbroken, even burdened by this cruel tie.
    m_Metadata:
      m_Items: []
  - m_Id: 846767270948900
    m_Localized: I'll show you the true nature of your Ill-Fated tie.
    m_Metadata:
      m_Items: []
  - m_Id: 849773190213632
    m_Localized: Well begun is half done. I must not fear.
    m_Metadata:
      m_Items: []
  - m_Id: 6953233644650496
    m_Localized: Even in this twisted Secular World, I shall illuminate the path.
    m_Metadata:
      m_Items: []
  - m_Id: 6953233707565056
    m_Localized: I will behold the merciful Buddha.
    m_Metadata:
      m_Items: []
  - m_Id: 6953233707565057
    m_Localized: Guided by the prayer beads, the chimes of Another Realm echo.
    m_Metadata:
      m_Items: []
  - m_Id: 6953233707565058
    m_Localized: ...Do not ask about my attire!
    m_Metadata:
      m_Items: []
  - m_Id: 6953233707565059
    m_Localized: This bizarre rhythm stirs up endless secular turmoil.
    m_Metadata:
      m_Items: []
  - m_Id: 6953233707565060
    m_Localized: ...Perhaps my words were a bit much.
    m_Metadata:
      m_Items: []
  - m_Id: 7777608321073152
    m_Localized: (...Keep my presence here strictly between us!)
    m_Metadata:
      m_Items: []
  - m_Id: 6953233707565061
    m_Localized: Tall iron towers and bright cascading lights all around...
    m_Metadata:
      m_Items: []
  - m_Id: 6953233707565062
    m_Localized: This too, is a grand rhythm woven by the secular world.
    m_Metadata:
      m_Items: []
  - m_Id: 7777608396570624
    m_Localized: All Qi flows as one. I shall gladly entrust myself to this current.
    m_Metadata:
      m_Items: []
  - m_Id: 9631275076681728
    m_Localized: Oh? For a mere human, such fearsome resolve.
    m_Metadata:
      m_Items: []
  - m_Id: 9631275135401984
    m_Localized: Yet, this is no place for you to dare look upon!
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
