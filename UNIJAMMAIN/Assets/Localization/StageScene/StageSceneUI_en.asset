  m_TableData:
  - m_Id: 28886827008
    m_Localized: 0. Temple Yard
    m_Metadata:
      m_Items: []
  - m_Id: 28953935872
    m_Localized: "Discipline begins.\LAs Master taught,\Lwell begun is half done."
    m_Metadata:
      m_Items: []
  - m_Id: 28958130176
    m_Localized: 'Difficulty: Easy


      Rank'
    m_Metadata:
      m_Items: []
  - m_Id: 28958130177
    m_Localized: 1. Deep Woods
    m_Metadata:
      m_Items: []
  - m_Id: 28958130178
    m_Localized: "Harmony is lost.\LI dare to begin\Lmy defiance."
    m_Metadata:
      m_Items: []
  - m_Id: 28958130179
    m_Localized: 'Difficulty: Easy


      Rank'
    m_Metadata:
      m_Items: []
  - m_Id: 28958130180
    m_Localized: 2. Cascade
    m_Metadata:
      m_Items: []
  - m_Id: 28958130181
    m_Localized: Beneath the crashing Cascade, I wash away my inner turmoil.
    m_Metadata:
      m_Items: []
  - m_Id: 28958130182
    m_Localized: 'Difficulty: Normal


      Rank'
    m_Metadata:
      m_Items: []
  - m_Id: 28958130183
    m_Localized: 3. The Peak
    m_Metadata:
      m_Items: []
  - m_Id: 28958130184
    m_Localized: "Drawn by fate\Lto the peak...\LA presence awaits."
    m_Metadata:
      m_Items: []
  - m_Id: 28958130185
    m_Localized: 'Difficulty: Hard


      Rank'
    m_Metadata:
      m_Items: []
  - m_Id: 28958130186
    m_Localized: 4. Prajna Dragon Boat
    m_Metadata:
      m_Items: []
  - m_Id: 28958130187
    m_Localized: "Leaving sorrow behind,\LI ascend the celestial path to my Karma."
    m_Metadata:
      m_Items: []
  - m_Id: 28958130188
    m_Localized: 'Difficulty: Hard


      Rank'
    m_Metadata:
      m_Items: []
  - m_Id: 28958130189
    m_Localized: 5. The Celestial Gates
    m_Metadata:
      m_Items: []
  - m_Id: 28958130190
    m_Localized: "After countless trials,\Lat the Celestial threshold.\LDark Spirits
      surge."
    m_Metadata:
      m_Items: []
  - m_Id: 28958130191
    m_Localized: 'Difficulty: Master


      Rank'
    m_Metadata:
      m_Items: []
  - m_Id: 28958130192
    m_Localized: 6. Celestial Temple
    m_Metadata:
      m_Items: []
  - m_Id: 28958130193
    m_Localized: "The Buddha... remains silent. My sole hope...\Lin this chaos."
    m_Metadata:
      m_Items: []
  - m_Id: 28958130194
    m_Localized: 'Difficulty: Master


      Rank'
    m_Metadata:
      m_Items: []
  - m_Id: 28958130195
    m_Localized: 7. The Below?
    m_Metadata:
      m_Items: []
  - m_Id: 28958130196
    m_Localized: "The root of disharmony.\LHere, at the final stand,\LI sever this
      ill-fated tie."
    m_Metadata:
      m_Items: []
  - m_Id: 28958130197
    m_Localized: 'Difficulty: Grandmaster


      Rank'
    m_Metadata:
      m_Items: []
  - m_Id: 28958130198
    m_Localized: E1. Winter Celebration
    m_Metadata:
      m_Items: []
  - m_Id: 28958130199
    m_Localized: "Red hats and\Lreindeer antlers.\LWinter discipline begins!"
    m_Metadata:
      m_Items: []
  - m_Id: 28958130200
    m_Localized: 'Difficulty: Normal


      Rank'
    m_Metadata:
      m_Items: []
  - m_Id: 28958130201
    m_Localized: E2. Secular Night
    m_Metadata:
      m_Items: []
  - m_Id: 28958130202
    m_Localized: Blinding lights and worldly noise. Pray, do not ask why I am here...
    m_Metadata:
      m_Items: []
  - m_Id: 28958130203
    m_Localized: 'Difficulty: Hard


      Rank'
    m_Metadata:
      m_Items: []
  - m_Id: 6558356299448320
    m_Localized: E3. Moonlight Dash
    m_Metadata:
      m_Items: []
  - m_Id: 6558356349779968
    m_Localized: "Atop an unfamiliar iron tower piercing the clouds.\LStrange lights
      all around.\LWhere are we headed?"
    m_Metadata:
      m_Items: []
  - m_Id: 6558356349779969
    m_Localized: 'Difficulty: Grandmaster


      Rank'
    m_Metadata:
      m_Items: []
  - m_Id: 6184490368630784
    m_Localized: Harmony shall be restored.
    m_Metadata:
      m_Items: []
  - m_Id: 6184490460905472
    m_Localized: 'Leaving the quiet temple,

      I face the endless path,

      and
      step forward.'
    m_Metadata:
      m_Items: []
  - m_Id: 6184490460905473
    m_Localized: Choose your path of discipline.
    m_Metadata:
      m_Items: []
  - m_Id: 6184490460905474
    m_Localized: Start >
    m_Metadata:
      m_Items: []
