  m_TableData:
  - m_Id: 28886827008
    m_Localized: "0. \uC808 \uC55E"
    m_Metadata:
      m_Items: []
  - m_Id: 28953935872
    m_Localized: "\uC218\uB828\uC758 \uC2DC\uC791.\L\uC2A4\uC2B9\uB2D8\uAED8\uC11C\uB294
      \uD56D\uC0C1 \uC2DC\uC791\uC774 \uACE7 \uBC18\uC774\uB77C \uD558\uC168\uC9C0."
    m_Metadata:
      m_Items: []
  - m_Id: 28958130176
    m_Localized: "\uB09C\uC774\uB3C4 : \uC785\uBB38 (\uD558)\n\n\uD65C\uC57D\uCE58"
    m_Metadata:
      m_Items: []
  - m_Id: 28958130177
    m_Localized: "1. \uC0B0\uC18D"
    m_Metadata:
      m_Items: []
  - m_Id: 28958130178
    m_Localized: "\uC870\uD654\uB97C \uC783\uC740 \uC138\uC0C1,\L\uB0B4 \uAC10\uD788
      \uB300\uC801\uC744 \uC2DC\uC791\uD558\uB9AC."
    m_Metadata:
      m_Items: []
  - m_Id: 28958130179
    m_Localized: "\uB09C\uC774\uB3C4 : \uC785\uBB38 (\uD558)\n\n\uD65C\uC57D\uCE58"
    m_Metadata:
      m_Items: []
  - m_Id: 28958130180
    m_Localized: "2. \uD3ED\uD3EC"
    m_Metadata:
      m_Items: []
  - m_Id: 28958130181
    m_Localized: "\uC3DF\uC544\uC9C0\uB294 \uD3ED\uD3EC \uC18D\uC5D0\uC11C,\uD750\uD2B8\uB7EC\uC9C4
      \uB9C8\uC74C\uC744 \uB2E4\uC7A1\uC790."
    m_Metadata:
      m_Items: []
  - m_Id: 28958130182
    m_Localized: "\uB09C\uC774\uB3C4 : \uC218\uB828 (\uC911)\n\n\uD65C\uC57D\uCE58"
    m_Metadata:
      m_Items: []
  - m_Id: 28958130183
    m_Localized: "3. \uC0B0 \uC815\uC0C1"
    m_Metadata:
      m_Items: []
  - m_Id: 28958130184
    m_Localized: "\uC6B4\uBA85\uCC98\uB7FC \uC774\uB04C\uB9B0 \uC0B0 \uC815\uC0C1.\L...\uB098\uB97C
      \uAE30\uB2E4\uB9AC\uACE0 \uC788\uC5C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 28958130185
    m_Localized: "\uB09C\uC774\uB3C4 : \uB2EC\uC778 (\uC911\uC0C1)\n\n\uD65C\uC57D\uCE58"
    m_Metadata:
      m_Items: []
  - m_Id: 28958130186
    m_Localized: "4. \uBC18\uC57C\uC6A9\uC120"
    m_Metadata:
      m_Items: []
  - m_Id: 28958130187
    m_Localized: "\uC2AC\uD514\uC744 \uB4A4\uB85C \uD558\uACE0,\L\uB098\uC758 \uC0AC\uBA85\uC744
      \uD5A5\uD574\L\uD558\uB298\uAE38\uC5D0 \uC624\uB978\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 28958130188
    m_Localized: "\uB09C\uC774\uB3C4 : \uB2EC\uC778 (\uC911\uC0C1)\n\n\uD65C\uC57D\uCE58"
    m_Metadata:
      m_Items: []
  - m_Id: 28958130189
    m_Localized: "5. \uCC9C\uB2F9 \uC55E"
    m_Metadata:
      m_Items: []
  - m_Id: 28958130190
    m_Localized: "\uC218\uB9CE\uC740 \uC2DC\uB828 \uB05D\uC5D0,\L\uB9C8\uCE68\uB0B4
      \uCC9C\uC0C1\uC758 \uBB38\uD131\uC5D0 \uC130\uB2E4.\L\uC545\uB839\uB4E4\uC774
      \uB354 \uBAB0\uC544\uCE58\uB294\uAD70."
    m_Metadata:
      m_Items: []
  - m_Id: 28958130191
    m_Localized: "\uB09C\uC774\uB3C4 : \uB3C4\uC0AC (\uC0C1)\n\n\uD65C\uC57D\uCE58"
    m_Metadata:
      m_Items: []
  - m_Id: 28958130192
    m_Localized: "6. \uCC9C\uB2F9"
    m_Metadata:
      m_Items: []
  - m_Id: 28958130193
    m_Localized: "\uBD80\uCC98\uB2D8\uAED8\uC11C\uB294...\L\uC544\uBB34 \uB9D0\uC500\uC774
      \uC5C6\uC73C\uC168\uB2E4.\L\uD63C\uB780 \uC18D \uC720\uC77C\uD588\uB358...
      \uD76C\uB9DD."
    m_Metadata:
      m_Items: []
  - m_Id: 28958130194
    m_Localized: "\uB09C\uC774\uB3C4 : \uB3C4\uC0AC (\uC0C1)\n\n\uD65C\uC57D\uCE58"
    m_Metadata:
      m_Items: []
  - m_Id: 28958130195
    m_Localized: "7. \uC9C0\uD558?"
    m_Metadata:
      m_Items: []
  - m_Id: 28958130196
    m_Localized: "\uBD80\uC870\uD654\uC758 \uC2DC\uC791\uACFC \uB05D. \uC774 \uACB0\uC804\uC758
      \uC7A5\uC18C\uC5D0\uC11C, \uC545\uC5F0\uC758 \uC885\uC9C0\uBD80\uB97C \uCC0D\uB294\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 28958130197
    m_Localized: "\uB09C\uC774\uB3C4 : \uC2E0\uC120 (\uCD5C\uC0C1)\n\n\uD65C\uC57D\uCE58"
    m_Metadata:
      m_Items: []
  - m_Id: 28958130198
    m_Localized: "E1. \uACA8\uC6B8\uB9DE\uC774"
    m_Metadata:
      m_Items: []
  - m_Id: 28958130199
    m_Localized: "\uBD89\uC740 \uBAA8\uC790\uC640 \uC21C\uB85D\uC758 \uBFD4. \uACA8\uC6B8\uB0A0\uC758
      \uC218\uB828\uC774 \uC2DC\uC791\uB41C\uB2E4!"
    m_Metadata:
      m_Items: []
  - m_Id: 28958130200
    m_Localized: "\uB09C\uC774\uB3C4 : \uC218\uB828 (\uC911)\n\n\uD65C\uC57D\uCE58"
    m_Metadata:
      m_Items: []
  - m_Id: 28958130201
    m_Localized: "E2. \uC18D\uC138\uC758 \uBC24"
    m_Metadata:
      m_Items: []
  - m_Id: 28958130202
    m_Localized: "\uBC88\uCA4D\uC774\uB294 \uBE5B, \uC9C0\uB3C5\uD55C \uC18D\uC138\uC758
      \uBC88\uB1CC. \uB0B4\uAC00 \uC65C \uC5EC\uAE30 \uC788\uB294\uC9C4 \uBB3B\uC9C0
      \uB9C8\uC2DC\uC624..."
    m_Metadata:
      m_Items: []
  - m_Id: 28958130203
    m_Localized: "\uB09C\uC774\uB3C4 : \uB2EC\uC778 (\uC911\uC0C1)\n\n\uD65C\uC57D\uCE58"
    m_Metadata:
      m_Items: []
  - m_Id: 6184490368630784
    m_Localized: "\uC870\uD654\uB97C \uB418\uCC3E\uC73C\uB9AC\uB77C."
    m_Metadata:
      m_Items: []
  - m_Id: 6184490460905472
    m_Localized: "\uACE0\uC694\uD588\uB358 \uC808\uC744 \uB4A4\uB85C \uD558\uACE0,\n\uB05D\uC5C6\uB294
      \uAE38 \uC704\uC5D0 \uC11C\uC11C,\n\uD55C \uAC78\uC74C, \uBC1C\uC744 \uB0B4\uB51B\uB294\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 6184490460905473
    m_Localized: "\n\n\uC218\uB828\uD560 \uC7A5\uC18C\uB97C\n\uBA3C\uC800 \uC120\uD0DD\uD558\uAC8C\uB098."
    m_Metadata:
      m_Items: []
  - m_Id: 6184490460905474
    m_Localized: "\uC2DC\uC791\uD558\uAE30 >"
    m_Metadata:
      m_Items: []
  - m_Id: 6184490460905475
    m_Localized: "\uC81C0\uB9C9"
    m_Metadata:
      m_Items: []
  - m_Id: 6184490460905476
    m_Localized: "\uACA8 \uC6B8"
    m_Metadata:
      m_Items: []
  - m_Id: 6184490460905477
    m_Localized: "\uB3C4 \uC2DC"
    m_Metadata:
      m_Items: []
  - m_Id: 6184490460905478
    m_Localized: "\uAC1C\uBB38"
    m_Metadata:
      m_Items: []
  - m_Id: 6184490460905479
    m_Localized: "\uD53C\uC548"
    m_Metadata:
      m_Items: []
  - m_Id: 6184490460905480
    m_Localized: "\uC545\uC5F0"
    m_Metadata:
      m_Items: []
  - m_Id: 6558356299448320
    m_Localized: "E3. \uB2EC\uBE5B \uC9C8\uC8FC"
    m_Metadata:
      m_Items: []
  - m_Id: 6558356349779968
    m_Localized: "\uAD6C\uB984\uC744 \uB6AB\uC740 \uB0AF\uC120 \uCCA0\uD0D1 \uC704.
      \uC0AC\uBC29\uC758 \uAE30\uC774\uD55C \uBE5B\uC904\uAE30. \uC6B0\uB9AC\uB294
      \uC5B4\uB514\uB97C \uD5A5\uD574 \uAC00\uB294 \uAC83\uC77C\uAE4C."
    m_Metadata:
      m_Items: []
  - m_Id: 6558356349779969
    m_Localized: "\uB09C\uC774\uB3C4 : \uC2E0\uC120 (\uCD5C\uC0C1)\n\n\uD65C\uC57D\uCE58"
    m_Metadata:
      m_Items: []
  - m_Id: 10937680221831168
    m_Localized: "\uC5F0\uC2B5\uBAA8\uB4DC"
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
